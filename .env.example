# Local development defaults. Use separate secrets in shared environments.
DATABASE_URL="postgresql://lifeflow:lifeflow@localhost:5433/lifeflow?schema=public"
DIRECT_URL="postgresql://lifeflow:lifeflow@localhost:5433/lifeflow?schema=public"
TEST_DATABASE_URL="postgresql://lifeflow_test:lifeflow_test@localhost:5434/lifeflow_test?schema=public"
APP_ORIGIN="http://localhost:3000"
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
USER_SESSION_ENCRYPTION_KEY="replace-with-a-base64-encoded-32-byte-key"
# Existing active ADMIN used by the reviewed-data import command.
LIFEFLOW_DATA_ADMIN_EMAIL="admin@example.com"
